# Research Engine Configuration

# Activos y timeframes por defecto
assets:
  - ticker: BTC
    exchange: CRYPTO
  - ticker: ETH
    exchange: CRYPTO
  - ticker: SOL
    exchange: CRYPTO

timeframes:
  - 1d
  - 4h

# Años de histórico a usar
years_of_data: 3

# Parámetros de backtest para experimentos
backtest:
  initial_capital: 100000
  slippage_bps: 5.0
  fee_bps: 10.0   # 0.1% Binance / Alpaca

# Espacio de hipótesis a explorar
hypotheses:
  trend:
    enabled: true
    fast_periods: [5, 9, 12, 20, 50]
    slow_periods: [21, 50, 100, 200]
    min_strength: [0.1, 0.2, 0.3]
    enable_short: [false, true]

  reversion:
    enabled: true
    rsi_periods: [7, 14, 21]
    oversold: [25, 28, 32, 35]
    overbought: [60, 65, 70, 75]
    enable_short: [false, true]

  momentum:
    enabled: true
    fast_periods: [3, 5, 7]
    slow_periods: [10, 15, 20]
    enable_short: [false, true]

  bollinger:
    enabled: true
    bb_period: [15, 20, 25]
    bb_std: [1.5, 2.0, 2.5]
    rsi_period: [7, 14]
    rsi_oversold: [35, 40, 45]
    rsi_overbought: [55, 60, 65]
    stop_loss_pcts: [3.0, 5.0]
    enable_short: [false, true]

# Filtros de robustez (los tres son obligatorios)
filters:
  min_trades: 10                # mínimo de trades para significancia estadística
  wf_min_sharpe_mean: 0.2       # Sharpe OOS promedio mínimo
  wf_min_consistency: 0.60      # 60% de splits walk-forward positivos
  param_robustness_min_score: 0.60  # 60% de variaciones ±10% mantienen edge
  param_variation_pct: 0.10     # ±10% en cada parámetro
  param_min_sharpe: 0.0         # Sharpe mínimo en variaciones

# Umbrales del informe
report:
  top_n: 5
  min_sharpe_to_show: 0.5
